#!/usr/bin/env bash
# hyperfetch-batch — parallel multi-URL fetch with shared team cache.
# Reads URLs from stdin (one per line) or from --urls-file.
# Runs hyperfetch with xargs -P<parallel> for concurrent execution.
# All fetches share the same --team-ns so dedupe works across the batch.

set -euo pipefail

PARALLEL=10
TEAM_NS="${CTS_TEAM_NS:-batch}"
MODE="prefetch"
STAGE_CAP="browser"
URLS_FILE=""
EXTRACT_PROMPT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --parallel|-P) PARALLEL="$2"; shift 2 ;;
    --team-ns) TEAM_NS="$2"; shift 2 ;;
    --stage) STAGE_CAP="$2"; shift 2 ;;
    --prefetch) MODE="prefetch"; shift ;;
    --summarize) MODE="summarize"; shift ;;
    --markdown) MODE="markdown"; shift ;;
    --extract) MODE="extract"; EXTRACT_PROMPT="$2"; shift 2 ;;
    --urls-file) URLS_FILE="$2"; shift 2 ;;
    -h|--help)
      cat <<HELP
hyperfetch-batch — parallel fetch with shared team cache

Usage:
  echo -e "url1\nurl2" | hyperfetch-batch [flags]
  hyperfetch-batch --urls-file urls.txt [flags]

Flags:
  --parallel <N>        Concurrent workers (default: 10)
  --team-ns <ns>        Cache namespace for the whole batch (default: 'batch')
  --stage <s>           Stage cap passed to each worker
  --prefetch            Zero-cost extraction (default)
  --summarize           Gemma bullet summary
  --markdown            Gemma clean markdown
  --extract "<prompt>"  Targeted fact extraction
  --urls-file <path>    Read URLs from file instead of stdin

Output: one JSON line per URL on stdout. Cache is shared across workers.
HELP
      exit 0 ;;
    *) echo "unknown flag: $1" >&2; exit 2 ;;
  esac
done

FLAGS=(--team-ns "$TEAM_NS" --stage "$STAGE_CAP")
case "$MODE" in
  prefetch) FLAGS+=(--prefetch) ;;
  summarize) FLAGS+=(--summarize) ;;
  markdown) FLAGS+=(--markdown) ;;
  extract) FLAGS+=(--extract "$EXTRACT_PROMPT") ;;
esac

if [[ -n "$URLS_FILE" ]]; then
  INPUT="$URLS_FILE"
  cat "$URLS_FILE"
else
  cat
fi | xargs -n1 -P"$PARALLEL" -I{} bash -c '
  out=$(hyperfetch "$1" "${@:2}" 2>/dev/null | tail -1)
  if [[ -n "$out" ]]; then
    echo "$out"
  else
    echo "{\"url\":\"$1\",\"error\":\"fetch failed\"}"
  fi
' _ {} "${FLAGS[@]}"
