#!/usr/bin/env bash
# hyperfetch — agent-facing wrapper for the Hyperstack 4-stage escalation chain.
# Called by PreToolUse hooks, subagents, and the /hyperstack skill.
#
# Usage:
#   hyperfetch <url> [--stage curl_cffi|camoufox|domshell|browser] [--team-ns NS]
#                    [--no-cache] [--summarize] [--json]
#
# Outputs single-line JSON (always). Never prints HTML.

set -euo pipefail

URL=""
STAGE_CAP="browser"
TEAM_NS="${CTS_TEAM_NS:-default}"
USE_CACHE=1
SUMMARIZE=1
OUT_MODE="json"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --stage) STAGE_CAP="$2"; shift 2 ;;
    --team-ns) TEAM_NS="$2"; shift 2 ;;
    --no-cache) USE_CACHE=0; shift ;;
    --no-summary) SUMMARIZE=0; shift ;;
    --summarize) SUMMARIZE=1; shift ;;
    --json) OUT_MODE="json"; shift ;;
    -h|--help)
      sed -n '3,13p' "$0"; exit 0 ;;
    *) URL="$1"; shift ;;
  esac
done

if [[ -z "$URL" ]]; then
  echo '{"error":"no url provided","usage":"hyperfetch <url> [flags]"}' >&2
  exit 2
fi

PATCHES="$HOME/patches"
TOOLSAVER="$HOME/claude-token-saver"
SANDBOX="$TOOLSAVER/plugins/team-sandbox.sh"
ML_FILTER="$TOOLSAVER/core/ml-filter.py"
GEMMA="$TOOLSAVER/core/gemma-gate.py"

stage_enabled() {
  local stage="$1"
  case "$STAGE_CAP" in
    curl_cffi) [[ "$stage" == "curl_cffi" ]] ;;
    camoufox)  [[ "$stage" == "curl_cffi" || "$stage" == "camoufox" ]] ;;
    domshell)  [[ "$stage" != "browser" ]] ;;
    *)         true ;;
  esac
}

emit() {
  # emit <stage> <status> <bytes> <tokens> <body-preview>
  local stage="$1" status="$2" bytes="$3" tokens="$4" preview="$5"
  printf '{"stage":"%s","status":%s,"url":"%s","bytes":%s,"tokens":%s,"team_ns":"%s","preview":%s}\n' \
    "$stage" "$status" "$URL" "$bytes" "$tokens" "$TEAM_NS" "$preview"
}

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
}

if [[ "$USE_CACHE" == "1" && -x "$SANDBOX" ]]; then
  HIT=$(CTS_TEAM_NS="$TEAM_NS" bash "$SANDBOX" lookup "$URL" 3600 2>/dev/null || true)
  if [[ -n "$HIT" && "$HIT" != "[]" ]]; then
    echo "$HIT" | python3 -c 'import json,sys
try:
  data=json.loads(sys.stdin.read())
  if data and isinstance(data,list) and len(data)>0:
    e=data[0]
    print(json.dumps({"stage":e.get("stage"),"status":200,"url":e.get("url"),"bytes":e.get("bytes",0),"tokens":e.get("token_estimate",0),"team_ns":"'"$TEAM_NS"'","cached":True,"preview":e.get("summary","")}))
    sys.exit(0)
except Exception: pass
sys.exit(1)' && exit 0 || true
  fi
fi

BODY=""
OUT_STAGE=""
OUT_STATUS=0
PY="$HOME/.cts/venv/bin/python"
HELPER="$HOME/.cts/bin/hyperfetch-stage.py"

run_stage() {
  local stage="$1"
  local json
  json=$("$PY" "$HELPER" --stage "$stage" --url "$URL" 2>/dev/null || true)
  [[ -z "$json" ]] && return 1
  local blocked status
  blocked=$(echo "$json" | python3 -c 'import json,sys;print(1 if json.load(sys.stdin).get("blocked") else 0)' 2>/dev/null || echo 0)
  status=$(echo "$json" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("status",0))' 2>/dev/null || echo 0)
  if [[ "$blocked" == "1" ]] || (( status < 200 )) || (( status >= 400 )); then return 1; fi
  BODY=$(echo "$json" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("body",""))' 2>/dev/null || true)
  [[ -z "$BODY" ]] && return 1
  OUT_STAGE="$stage"
  OUT_STATUS="$status"
  return 0
}

stage_enabled "curl_cffi" && run_stage "curl_cffi" || true
[[ -z "$BODY" ]] && stage_enabled "camoufox" && run_stage "camoufox" || true
[[ -z "$BODY" ]] && stage_enabled "domshell" && run_stage "domshell" || true
[[ -z "$BODY" ]] && stage_enabled "browser"  && run_stage "browser"  || true

if [[ -z "$BODY" || -z "$OUT_STAGE" ]]; then
  emit "failed" 0 0 0 '""'
  exit 1
fi

BYTES=$(printf "%s" "$BODY" | wc -c | tr -d ' ')

KEEP=1
if [[ -x "$ML_FILTER" ]]; then
  CLASSIFY=$(printf "%s" "$BODY" | head -c 65536 | "$HOME/.cts/venv/bin/python" "$ML_FILTER" --classify 2>/dev/null || echo '{"keep":true}')
  KEEP=$(echo "$CLASSIFY" | python3 -c 'import json,sys; print(1 if json.load(sys.stdin).get("keep",True) else 0)' 2>/dev/null || echo 1)
fi

if [[ "$KEEP" == "0" ]]; then
  emit "$OUT_STAGE" "$OUT_STATUS" "$BYTES" 5 '"[filtered: noise]"'
  exit 0
fi

SUMMARY_BODY="$BODY"
if [[ "$SUMMARIZE" == "1" && -x "$GEMMA" ]]; then
  GEMMA_OUT=$(printf "%s" "$BODY" | head -c 131072 | "$HOME/.cts/venv/bin/python" "$GEMMA" --summarize 2>/dev/null || true)
  if [[ -n "$GEMMA_OUT" ]]; then
    SUMMARY_BODY="$GEMMA_OUT"
  fi
fi

PREVIEW=$(printf "%s" "$SUMMARY_BODY" | head -c 2000 | json_escape)
TOKENS=$(( $(printf "%s" "$SUMMARY_BODY" | wc -c | tr -d ' ') / 4 + 1 ))
HASH=$(printf "%s" "$BODY" | shasum | awk '{print $1}' | head -c 16)

if [[ "$USE_CACHE" == "1" && -x "$SANDBOX" ]]; then
  SUMMARY_FOR_CACHE=$(printf "%s" "$SUMMARY_BODY" | head -c 4000)
  CTS_TEAM_NS="$TEAM_NS" bash "$SANDBOX" record "$URL" "$OUT_STAGE" "$BYTES" "$HASH" "$TOKENS" "$SUMMARY_FOR_CACHE" 2>/dev/null || true
fi

emit "$OUT_STAGE" "$OUT_STATUS" "$BYTES" "$TOKENS" "$PREVIEW"
